[project]
name = "{{ project_name }}"
description = "{{ description }}"
lang = "{{ lang }}"

[ci]
command = "{{ ci_command }}"
architecture_check = ""
frontend_dir = ""

[drivers]
default = "{{ driver_mode }}"  # auto / cursor / codex

[drivers.roles]
{% if roles -%}
{% for role, driver in roles.items() -%}
{{ role }} = "{{ driver }}"
{% endfor -%}
{% else -%}
# planner = "codex"
# builder = "cursor"
# evaluator = "codex"
{% endif %}
[models]
default = ""  # 留空 = 使用 IDE/CLI 默认模型

# 按驱动设置默认模型（cursor / codex）
# [models.driver_defaults]
# codex = "o3"
# cursor = "claude-sonnet-4-20250514"

# 按角色覆盖模型（优先级高于 driver_defaults 和 default）
# 支持角色: planner / builder / evaluator / alignment_evaluator / strategist / reflector / advisor
# [models.role_overrides]
# planner = "o3-pro"
# builder = "claude-sonnet-4-20250514"

[workflow]
max_iterations = 3
pass_threshold = 3.5
auto_merge = true
branch_prefix = "agent"

[autonomous]
enabled = true
max_tasks_per_session = 10
progress_report_interval = 5
consecutive_block_limit = 2

[integrations.memverse]
enabled = {{ memverse_enabled | lower }}
driver = "{{ memverse_driver }}"
domain_prefix = "{{ memverse_domain }}"
